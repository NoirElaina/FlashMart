<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.flashmart.product.mapper.ProductMapper">
    <!-- 首页商品分页。category 为空时不加分类条件，返回全部商品。 -->
    <select id="pageProducts" resultType="org.example.flashmart.product.model.dataobject.ProductDO">
        select
            id,
            name,
            image,
            category,
            original_price as originalPrice,
            sale_price as salePrice,
            stock,
            sold,
            is_hot as hot,
            is_seckill as seckill,
            limit_per_user as limitPerUser,
            seckill_start_time as seckillStartTime,
            seckill_end_time as seckillEndTime,
            status,
            create_time as createTime,
            update_time as updateTime
        from products
        <where>
            <if test="category != null and category != ''">
                category = #{category}
            </if>
        </where>
        limit #{offset}, #{pageSize}
    </select>

    <!-- 分页总数必须和 pageProducts 保持相同筛选条件。 -->
    <select id="countProducts" resultType="long">
        select count(*)
        from products
        <where>
            <if test="category != null and category != ''">
                category = #{category}
            </if>
        </where>
    </select>
</mapper>
